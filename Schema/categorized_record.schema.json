{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "categorized_record.schema.json",
  "title": "CategorizedRecord",
  "description": "A single categorized transaction row, derived from schemas.py and storage.py.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "date": {
      "description": "Date string or ISO-like date value. In runtime Python this may also be a datetime.date object.",
      "type": "string",
      "minLength": 1,
      "examples": [
        "2024-01-01",
        "01/31/2024"
      ]
    },
    "merchant": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "Store"
      ]
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "Shopping"
      ]
    },
    "subcategory": {
      "type": "string",
      "examples": [
        "Groceries"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0
    },
    "match_type": {
      "type": "string",
      "examples": [
        "exact",
        "fuzzy",
        "unknown"
      ]
    }
  },
  "required": [
    "date",
    "merchant",
    "amount",
    "category"
  ]
}
